{
	// Place your snippets for cpp here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
		 "Print to console": {
	 	"prefix": "pd",
	 	"body": [
	 		"printf(\"%d\", 42);",
	 	],
	 	"description": "Log output to console"
	 },
	 "Coplien form header": {
		"prefix": "hcoplien",
		"body": [
			"#ifndef ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_${TM_FILENAME/^.*\\.([^\\.]*)$/${1:/upcase}/}",
			"#define ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_${TM_FILENAME/^.*\\.([^\\.]*)$/${1:/upcase}/}",
			"",
			"class ${TM_FILENAME_BASE}",
			"{",
			"private:",
			"",
			"public:",
			"\t${TM_FILENAME_BASE}();",
			"\t~${TM_FILENAME_BASE}();",
			"\t${TM_FILENAME_BASE}(${TM_FILENAME_BASE} const &other);",
			"\t${TM_FILENAME_BASE} &operator=(${TM_FILENAME_BASE} const &other);",
			"};",
			"",
			"#endif /* ${TM_FILENAME_BASE/(.*)/${1:/upcase}/}_${TM_FILENAME/^.*\\.([^\\.]*)$/${1:/upcase}/} */"
		]
	},
	"Coplien form source": {
		"prefix": "ccoplien",
		"body": [
			"#include \"${TM_FILENAME_BASE}.hpp\"",
			"",
			"${TM_FILENAME_BASE}::${TM_FILENAME_BASE}()",
			"{",
			"}",
			"",
			"${TM_FILENAME_BASE}::~${TM_FILENAME_BASE}()",
			"{",
			"}",
			"",
			"${TM_FILENAME_BASE}::${TM_FILENAME_BASE}(${TM_FILENAME_BASE} const &other)",
			"{",
			"\t*this = other;",
			"}",
			"",
			"${TM_FILENAME_BASE} &${TM_FILENAME_BASE}::operator=(${TM_FILENAME_BASE} const &other)",
			"{",
			"\tif (this != &other)",
			"\t{",
			"\t}",
			"\treturn *this;",
			"}"
		]
	},
	"Stream Operator": {
		"prefix": "opst",
		"body": [
			"std::ostream &operator<<(std::ostream &os, ${TM_FILENAME_BASE} const &${TM_FILENAME_BASE/(.*)/${1:/downcase}/})",
			"{",
			"\tos << $1;",
			"\treturn os;",
			"}"
		]
	}
}