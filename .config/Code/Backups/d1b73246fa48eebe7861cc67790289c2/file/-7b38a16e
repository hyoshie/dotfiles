#include "../../includes/mandatory/init_structs.h"

//有効なマップか調べるメインの関数
int	check_map(t_map *map, t_hero *hero, t_game *game)
{
	size_t	idx;

	idx = 0;
	while (map->vector[idx])
		idx++;
	map->height = idx;
	if (map->height < 3)
		exit_because_err("map rows are less than 3.", MAP, game);
	map->width = ft_strlen(*map->vector);
	check_rectangle(map->vector, *map, game);
	check_character(map->vector, map, hero, game);
	check_wall_exist(map->vector, *map, game);
	check_CEP(*map, game);
	return (0);
}
